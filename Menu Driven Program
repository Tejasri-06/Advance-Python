
def square():
  side=int(input("Enter side:"))
  area=side*side
  print("Area:",area)
def rect(l,b):
  area=l*b
  print("Area:",area)
def cir():
  r=int(input("Enter radius:"))
  res=3.14*r*r
  return res
def tri(h,b):
  area=0.5*h*b
  return area
while True:
